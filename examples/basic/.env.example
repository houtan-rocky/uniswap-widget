# Copy this file to .env and update with your values

# WalletConnect/AppKit Configuration
# Get your project ID from https://cloud.walletconnect.com/
VITE_REOWN_PROJECT_ID=your_walletconnect_project_id_here

# App Metadata - This information will be displayed in wallet connection prompts
VITE_APP_NAME=Uniswap Widget Package
VITE_APP_DESCRIPTION=Clean Uniswap swap widget for easy integration
VITE_APP_URL=https://your-domain.com
VITE_APP_ICON=https://avatars.githubusercontent.com/u/179229932

# Uniswap gateway API key used by the dev-server proxy (vite.config.ts)
VITE_UNISWAP_API_KEY=your_uniswap_api_key_here

# Uniswap gateway API key used by the Vercel serverless functions (api/*.js)
UNISWAP_API_KEY=your_uniswap_api_key_here

# Optional  token-change controls (default: true)
VITE_ALLOW_SELL_TOKEN_CHANGE=true
VITE_ALLOW_BUY_TOKEN_CHANGE=true 